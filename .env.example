# Copy this file to .env and fill in your values
# Mac/Linux:  cp .env.example .env
# Windows:    copy .env.example .env

# ── Selecciona el modo en config.py ─────────────────────────
#   MODE = "PAPER"  →  usa BINANCE_API_KEY / BINANCE_API_SECRET
#   MODE = "REAL"   →  usa BINANCE_API_KEY_REAL / BINANCE_API_SECRET_REAL

# ── PAPER mode — testnet.binancefuture.com ──────────────────
# 1. Entra a https://testnet.binancefuture.com con GitHub
# 2. API Key → Generate (sin restricción de IP)
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# ── REAL mode — binance.com ─────────────────────────────────
# 1. Entra a https://binance.com/en/my/settings/api-management
# 2. Create API → Enable Futures → sin restricción de IP
BINANCE_API_KEY_REAL=your_mainnet_api_key_here
BINANCE_API_SECRET_REAL=your_mainnet_api_secret_here
